    { "name": "planStatusId",    "columnName": "plan_status_id",   "type": "Long",          "nullable": false, "filterable": true,  "searchable": false, "sortable": false, "validations": [{ "annotation": "NotNull", "message": "Plan status is required" }] },
    { "name": "submittedAt",     "columnName": "submitted_at",     "type": "LocalDateTime", "nullable": true,  "filterable": false, "searchable": false, "sortable": false, "validations": [] },
